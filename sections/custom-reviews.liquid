<script>
  (function() {
    const sectionId = "section-{{ section.id }}";
    const section = document.getElementById(sectionId);
    if (!section) return;

    const desktopMq = window.matchMedia("(min-width: 769px)");
    const MAX_CHARS = 250;

    function truncateText(text, maxChars) {
      const clean = (text || "").replace(/\s+/g, " ").trim();
      if (clean.length <= maxChars) return clean;

      let truncated = clean.slice(0, maxChars);
      const lastSpace = truncated.lastIndexOf(" ");
      if (lastSpace > 0) {
        truncated = truncated.slice(0, lastSpace);
      }

      return truncated + "...";
    }

    function setupReviewToggles() {
      const cards = section.querySelectorAll(".custom-review-card");

      cards.forEach((card) => {
        const preview = card.querySelector("[data-review-body-preview]");
        const full = card.querySelector("[data-review-body-full]");
        const toggleWrap = card.querySelector("[data-review-read-more]");
        const toggleBtn = card.querySelector("[data-review-toggle]");

        if (!preview || !full || !toggleWrap || !toggleBtn) return;

        const fullText = full.textContent.replace(/\s+/g, " ").trim();
        card.classList.remove("is-collapsible", "is-expanded");
        toggleWrap.hidden = true;

        if (desktopMq.matches) {
          if (fullText.length > MAX_CHARS) {
            card.classList.add("is-collapsible");
            preview.textContent = truncateText(fullText, MAX_CHARS);
            toggleWrap.hidden = false;
          } else {
            preview.textContent = fullText;
            toggleWrap.hidden = false;
          }
        } else {
          preview.textContent = "";
          toggleWrap.hidden = false;
        }

        if (!toggleBtn.dataset.bound) {
          toggleBtn.addEventListener("click", function() {
            card.classList.toggle("is-expanded");
          });

          toggleBtn.dataset.bound = "true";
        }
      });
    }

    setupReviewToggles();

    let resizeTimer;
    window.addEventListener("resize", function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(setupReviewToggles, 180);
    });

    document.addEventListener("shopify:section:load", setupReviewToggles);
    document.addEventListener("shopify:block:select", setupReviewToggles);
  })();
</script>

