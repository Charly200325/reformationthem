      "settings": {
        "title": "",
        "custom_HTML": "<style>\n/* Conteneur principal */\n.tm_tracking_content {\n  max-width: 900px;\n  margin: 50px auto;\n  width: 100%;\n  font-family: \"Inter\", Arial, sans-serif;\n  padding: 0 15px;\n  text-align: center;\n}\n\n/* Titre */\n.tm_tracking_title {\n  font-size: 26px;\n  margin-bottom: 40px;\n  font-weight: 600;\n  color: #111;\n}\n\n/* Conteneur des formulaires */\n.tm_tracking_form_in {\n  display: flex;\n  flex-direction: column;\n  gap: 30px;\n  align-items: center;\n}\n\n/* Desktop : côte à côte */\n@media(min-width: 992px) {\n  .tm_tracking_form_in {\n    flex-direction: row;\n    justify-content: center;\n    align-items: center;\n    gap: 40px;\n  }\n}\n\n/* Bloc formulaire */\n.tm_tracking_form_box {\n  flex: 1;\n  padding: 25px;\n  border: 1px solid #eee;\n  border-radius: 10px;\n  background: #fff;\n  box-shadow: 0 2px 6px rgba(0,0,0,0.05);\n  min-width: 260px;\n}\n\n/* Champ */\n.tm_tracking_parent {\n  text-align: left;\n  margin-bottom: 18px;\n}\n\n.tm_tracking_parent label {\n  font-weight: 500;\n  font-size: 14px;\n  margin-bottom: 6px;\n  display: block;\n  color: #333;\n}\n\n.tm_tracking_parent input {\n  padding: 12px 14px;\n  border: 1px solid #ddd;\n  border-radius: 6px;\n  width: 100%;\n  font-size: 14px;\n  transition: border-color 0.3s;\n}\n\n.tm_tracking_parent input:focus {\n  border-color: #111;\n  outline: none;\n}\n\n/* Bouton */\n.tm_tracking_button button {\n  width: 100%;\n  padding: 12px;\n  background: #2e413d;\n  color: #fff;\n  font-size: 15px;\n  font-weight: 500;\n  border: 2px solid #2e413d;\n  border-radius: 6px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n\n/* Hover + focus + active : inversion */\n.tm_tracking_button button:hover,\n.tm_tracking_button button:focus,\n.tm_tracking_button button:active {\n  background: #fff;\n  color: #2e413d;\n  border: 2px solid #2e413d;\n}\n\n/* Message d'erreur */\n.tm_tracking_alert {\n  color: #d00;\n  font-size: 12px;\n  display: none;\n  margin-top: 5px;\n}\n\n/* Séparateur \"OR\" */\n.tm_tracking_separator {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #666;\n  font-weight: 600;\n  font-size: 14px;\n  text-transform: uppercase;\n  white-space: nowrap;\n}\n\n.tm_tracking_separator::before,\n.tm_tracking_separator::after {\n  content: \"\";\n  flex: 1;\n  border-top: 1px dashed #aaa;\n}\n\n.tm_tracking_separator::before {\n  margin-right: 12px;\n}\n\n.tm_tracking_separator::after {\n  margin-left: 12px;\n}\n\n/* En desktop => vertical */\n@media(min-width: 992px) {\n  .tm_tracking_separator {\n    flex-direction: column;\n    font-size: 13px;\n  }\n\n  .tm_tracking_separator::before,\n  .tm_tracking_separator::after {\n    content: \"\";\n    flex: none;\n    width: 1px;\n    height: 40px;\n    border-top: none;\n    border-left: 1px dashed #aaa;\n  }\n\n  .tm_tracking_separator::before {\n    margin: 0 0 8px 0;\n  }\n\n  .tm_tracking_separator::after {\n    margin: 8px 0 0 0;\n  }\n}\n</style>\n\n<div class=\"tm_tracking_content\">\n\n  <div class=\"tm_tracking_form_in\">\n\n    <!-- Formulaire par numéro de commande -->\n    <div class=\"tm_tracking_form_box\">\n      <form action=\"\" method=\"get\" class=\"tm_tracking_form\">\n\n        <div class=\"tm_tracking_parent\">\n          <label for=\"tms_order_number\">Order Number</label>\n          <input id=\"tms_order_number\" type=\"text\" name=\"order\" placeholder=\"Ex : #12345\">\n          <span class=\"tm_tracking_alert\">Please enter your order number</span>\n        </div>\n\n        <div class=\"tm_tracking_parent\">\n          <label for=\"tms_order_email\">Email</label>\n          <input id=\"tms_order_email\" type=\"email\" name=\"email\" placeholder=\"exemple@email.com\">\n          <span class=\"tm_tracking_alert\">Please enter your email address</span>\n        </div>\n\n        <div class=\"tm_tracking_button\">\n          <button type=\"submit\">Track</button>\n        </div>\n\n      </form>\n    </div>\n\n    <!-- Séparateur -->\n    <div class=\"tm_tracking_separator\">OR</div>\n\n    <!-- Formulaire par numéro de suivi -->\n    <div class=\"tm_tracking_form_box\">\n      <form action=\"\" method=\"get\" class=\"tm_tracking_form\">\n\n        <div class=\"tm_tracking_parent\">\n          <label for=\"tms_track_number\">Tracking Number</label>\n          <input id=\"tms_track_number\" type=\"text\" name=\"nums\" placeholder=\"Ex : 1Z999AA10123456784\">\n          <span class=\"tm_tracking_alert\">Please enter your tracking number</span>\n        </div>\n\n        <div class=\"tm_tracking_button\">\n          <button type=\"submit\">Track</button>\n        </div>\n\n      </form>\n    </div>\n\n  </div>\n</div>"
      }
