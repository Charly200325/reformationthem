rapper-ed6fb6fc748b7b5a\">\n          <span class=\"animate-icon\"></span>\n        </button>\n      <span class=\"swiper-notification\" aria-live=\"assertive\" aria-atomic=\"true\"></span>\n</div>      \n      \n    </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js\"></script>\n\n<script src=\"https://cdn.jsdelivr.net/npm/vanilla-lazyload@19.1.3/dist/lazyload.min.js\"></script>\n\n\n<script>\n  function initVideoFromSocial3() {\n    let lazyLoadInstance = new LazyLoad();\n    window.addEventListener(\"LazyLoad::Initialized\", function (event) {\n      window.lazyLoadInstance = event.detail.instance;\n    }, false);\n\n    document.querySelector('.video-social-slider-template--21503048089929__video_from_social_3_A4kYJf').classList.remove('preview');\n\n    // Toutes les vidéos en muet\n    document.querySelectorAll('.video-social-card-template--21503048089929__video_from_social_3_A4kYJf video').forEach(video => {\n      video.muted = true;\n    });\n\n    function playActiveVideo(swiper) {\n      // reset toutes les vidéos\n      document.querySelectorAll('.video-social-card-template--21503048089929__video_from_social_3_A4kYJf video').forEach(v => {\n        v.pause();\n        v.currentTime = 0;\n        v.muted = true;\n      });\n\n      document.querySelectorAll('.video-social-action-template--21503048089929__video_from_social_3_A4kYJf')\n        .forEach(b => b.classList.remove('active'));\n\n      const activeSlide = swiper.slides[swiper.activeIndex];\n      if (!activeSlide) return;\n\n      const video = activeSlide.querySelector('video');\n      const btn = activeSlide.querySelector('.video-social-action-template--21503048089929__video_from_social_3_A4kYJf');\n\n      if (video) {\n        video.muted = true;\n        video.play().catch(() => {});\n        btn?.classList.add('active');\n      }\n    }\n\n    const slider = new Swiper(\".video-social-slider-template--21503048089929__video_from_social_3_A4kYJf\", {\n      speed: 300,\n      spaceBetween: 20,\n      loop: true,\n\n      autoplay: {\n        delay: 3000, // vitesse du slide\n        disableOnInteraction: false,\n        pauseOnMouseEnter: true\n      },\n\n      navigation: {\n        nextEl: '.video-social-btn-next-template--21503048089929__video_from_social_3_A4kYJf',\n        prevEl: '.video-social-btn-prev-template--21503048089929__video_from_social_3_A4kYJf',\n      },\n\n      breakpoints: {\n        320: { slidesPerView: 1.4, spaceBetween: 20 },\n        768: { slidesPerView: 2, spaceBetween: 20 },\n        1024: { slidesPerView: 4, spaceBetween: 20 }\n      },\n\n      on: {\n        init: function () {\n          playActiveVideo(this);\n        },\n        slideChangeTransitionEnd: function () {\n          playActiveVideo(this);\n        }\n      }\n    });\n\n    // click manuel play/pause\n    document.querySelectorAll('.video-social-card-template--21503048089929__video_from_social_3_A4kYJf').forEach(el => {\n      const btn = el.querySelector('.video-social-action-template--21503048089929__video_from_social_3_A4kYJf');\n      const video = el.querySelector('video');\n\n      if (!btn || !video) return;\n\n      btn.addEventListener('click', () => {\n        const isActive = btn.classList.toggle('active');\n\n        document.querySelectorAll('.video-social-card-template--21503048089929__video_from_social_3_A4kYJf video').forEach(v => {\n          if (v !== video) {\n            v.pause();\n            v.currentTime = 0;\n            v.muted = true;\n          }\n        });\n\n        document.querySelectorAll('.video-social-action-template--21503048089929__video_from_social_3_A4kYJf').forEach(b => {\n          if (b !== btn) b.classList.remove('active');\n        });\n\n        if (isActive) {\n          video.play();\n        } else {\n          video.pause();\n        }\n      });\n    });\n\n    // stop vidéo hors écran\n    const observer = new IntersectionObserver(entries => {\n      entries.forEach(entry => {\n        const video = entry.target.querySelector('video');\n        const btn = entry.target.querySelector('.video-social-action-template--21503048089929__video_from_social_3_A4kYJf');\n        if (!entry.isIntersecting && video && !video.paused) {\n          video.pause();\n          video.currentTime = 0;\n          btn?.classList.remove('active');\n        }\n      });\n    }, { threshold: 0.2 });\n\n    document.querySelectorAll('.video-social-card-template--21503048089929__video_from_social_3_A4kYJf').forEach(card => {\n      observer.observe(card);\n    });\n  }\n\n  document.addEventListener('DOMContentLoaded', initVideoFromSocial3);\n\n  if (Shopify.designMode) {\n    document.addEventListener('shopify:section:unload', initVideoFromSocial3);\n    document.addEventListener('shopify:section:load', initVideoFromSocial3);\n  }\n</script>\n\n</div>"
