        "custom_liquid_HxCPtY": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% assign seconds_in_day = 86400 %}\n{% assign days_to_add = 6 %}\n{% assign offset_seconds = seconds_in_day | times: days_to_add | plus: 7200 %}\n{% assign delivery_timestamp = 'now' | date: '%s' | plus: offset_seconds %}\n\n<div class=\"flex items-center justify-center xl:justify-start mt-[20px] xl:mt-[30px]\">\n  <img src=\"{{ 'truck.svg' | asset_url }}\" alt=\"\" class=\"w-[24px] h-[24px] shrink-0\">\n  <div class=\"ml-[10px] xl:ml-[20px] text-[11px] xl:text-[14px] text-gray-900 uppercase leading-[110%] [text-box:trim-both_cap_alphabetic]\">\n    <p>Livraison estimée le {{ delivery_timestamp | date: '%A %-d %B' | upcase }}.</p>\n    <p>Commandez dans les <span id=\"countdown\"></span>.</p>\n  </div>\n</div>\n\n<script>\n  function updateCountdown() {\n    const now = new Date();\n\n    // Minuit du jour de livraison = deadline de commande\n    const deadline = new Date();\n    deadline.setDate(deadline.getDate() + 6);\n    deadline.setHours(23, 59, 59, 0);\n\n    const diff = deadline - now;\n\n    if (diff <= 0) {\n      document.getElementById('countdown').textContent = '0h00min';\n      return;\n    }\n\n    const totalMinutes = Math.floor(diff / 1000 / 60);\n    const hours = Math.floor(totalMinutes / 60);\n    const minutes = totalMinutes % 60;\n\n    document.getElementById('countdown').textContent =\n      hours + 'h' + String(minutes).padStart(2, '0') + 'min';\n  }\n\n  updateCountdown();\n  setInterval(updateCountdown, 1000);\n</script>"
          }
        }
      },
